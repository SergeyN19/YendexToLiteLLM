# Yandex Cloud IAM API key (starts with "AQVN...")
YANDEX_API_KEY=your_yandex_api_key_here

# Yandex Cloud folder ID (e.g. b1gf32s7vvpjd9av0j2o)
YANDEX_FOLDER_ID=your_folder_id_here

# Master key to authenticate requests to the LiteLLM proxy (choose any string)
LITELLM_MASTER_KEY=sk-my-secret-key

# PostgreSQL credentials (used by db, litellm and litellm-pgvector services)
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me_password
